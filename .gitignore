# ══════════════════════════════════════════════════════════════
# Android Build
# ══════════════════════════════════════════════════════════════
*.apk
*.aab
*.ap_
*.dex
*.class
bin/
gen/
out/
build/
.gradle/
.kotlin/
captures/
*.hprof

# ══════════════════════════════════════════════════════════════
# Android Studio / IntelliJ
# ══════════════════════════════════════════════════════════════
.idea/
*.iml
.externalNativeBuild
.cxx/
local.properties

# ══════════════════════════════════════════════════════════════
# Python / ML Pipeline
# ══════════════════════════════════════════════════════════════
ml_pipeline/.venv/
ml_pipeline/output/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
*.egg

# ══════════════════════════════════════════════════════════════
# Models (large binaries)
# ══════════════════════════════════════════════════════════════
*.tflite
*.onnx
*.h5
*.pb
app/src/main/assets/*.tflite

# ══════════════════════════════════════════════════════════════
# Logs & Temporary Files
# ══════════════════════════════════════════════════════════════
logs/
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# ══════════════════════════════════════════════════════════════
# Node.js (web-editor)
# ══════════════════════════════════════════════════════════════
node_modules/
.npm/
.yarn/

# ══════════════════════════════════════════════════════════════
# Keystore (security)
# ══════════════════════════════════════════════════════════════
*.jks
*.keystore

# ══════════════════════════════════════════════════════════════
# OS Files
# ══════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db

# ══════════════════════════════════════════════════════════════
# Reference APKs (large binaries)
# ══════════════════════════════════════════════════════════════
referencia/

# ══════════════════════════════════════════════════════════════
# OpenSpec (only commit archived changes)
# ══════════════════════════════════════════════════════════════
openspec/changes/*/
!openspec/changes/archive/
