<?xml version="1.0" encoding="utf-8"?>
<!-- 
5-row Compact Layout - Similar a Hacker's Keyboard compact
11 columnas, más compacto que kbd_pc.xml
-->
<Keyboard
    xmlns:android="http://schemas.android.com/apk/res-auto"
    android:keyWidth="9.09090909%p"
    android:horizontalGap="0px"
    android:verticalGap="@dimen/key_bottom_gap">

    <!-- Row 1: Extension - Esc + símbolos + Home/End/Del -->
    <Row android:extension="true" android:rowEdgeFlags="top">
        <Key
            android:codes="@integer/key_escape"
            android:keyLabel="Esc"
            android:isModifier="true"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="`" android:shiftLabel="~" />
        <Key android:keyLabel="-" android:shiftLabel="_" />
        <Key android:keyLabel="\\" android:shiftLabel="|" />
        <Key android:keyLabel=";" android:shiftLabel=":" />
        <Key android:keyLabel="=" android:shiftLabel="+" />
        <Key android:keyLabel="[" android:shiftLabel="{" />
        <Key android:keyLabel="]" android:shiftLabel="}" />
        <Key
            android:codes="@integer/key_home"
            android:keyLabel="Home"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_end"
            android:keyLabel="End"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_forward_del"
            android:keyLabel="Del"
            android:isModifier="true"
            android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: Números 1-0 + Delete -->
    <Row>
        <Key
            android:keyLabel="1"
            android:shiftLabel="!"
            android:popupCharacters="!\`"
            android:keyWidth="7.09090909%p"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="2" android:shiftLabel="@" android:popupCharacters="@~" />
        <Key android:keyLabel="3" android:shiftLabel="#" android:popupCharacters="#-" />
        <Key android:keyLabel="4" android:shiftLabel="$" android:popupCharacters="$_" />
        <Key android:keyLabel="5" android:shiftLabel="%" android:popupCharacters="%=" />
        <Key android:keyLabel="6" android:shiftLabel="^" android:popupCharacters="^+" />
        <Key android:keyLabel="7" android:shiftLabel="&amp;" android:popupCharacters="{&amp;" />
        <Key android:keyLabel="8" android:shiftLabel="*" android:popupCharacters="}*" />
        <Key android:keyLabel="9" android:shiftLabel="(" android:popupCharacters="([" />
        <Key android:keyLabel="0" android:shiftLabel=")" android:popupCharacters=")]" />
        <Key
            android:codes="@integer/key_delete"
            android:keyLabel="⌫"
            android:keyWidth="11.09090909%p"
            android:isModifier="true"
            android:isRepeatable="true"
            android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: QWERTY -->
    <Row>
        <Key android:keyLabel="q" android:keyEdgeFlags="left" />
        <Key android:keyLabel="w" />
        <Key android:keyLabel="e" />
        <Key android:keyLabel="r" />
        <Key android:keyLabel="t" />
        <Key android:keyLabel="y" />
        <Key android:keyLabel="u" />
        <Key android:keyLabel="i" />
        <Key android:keyLabel="o" />
        <Key android:keyLabel="p" android:keyWidth="18.18181818%p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 4: Tab + ASDFGHJKL + Enter -->
    <Row>
        <Key
            android:codes="@integer/key_tab"
            android:keyLabel="Tab"
            android:keyWidth="10.5%p"
            android:isModifier="true"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="a" android:keyWidth="8.6%p" />
        <Key android:keyLabel="s" android:keyWidth="8.6%p" />
        <Key android:keyLabel="d" android:keyWidth="8.6%p" />
        <Key android:keyLabel="f" android:keyWidth="8.6%p" />
        <Key android:keyLabel="g" android:keyWidth="8.6%p" />
        <Key android:keyLabel="h" android:keyWidth="8.6%p" />
        <Key android:keyLabel="j" android:keyWidth="8.6%p" />
        <Key android:keyLabel="k" android:keyWidth="8.6%p" />
        <Key android:keyLabel="l" android:keyWidth="8.6%p" />
        <Key
            android:codes="@integer/key_return"
            android:keyLabel="↵"
            android:keyWidth="14%p"
            android:isModifier="true"
            android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 5: Shift + ZXCVBNM + ↑ + . -->
    <Row>
        <Key
            android:codes="@integer/key_shift"
            android:keyLabel="⇧"
            android:keyWidth="11.09090909%p"
            android:isModifier="true"
            android:isSticky="true"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="z" />
        <Key android:keyLabel="x" />
        <Key android:keyLabel="c" />
        <Key android:keyLabel="v" />
        <Key android:keyLabel="b" />
        <Key android:keyLabel="n" />
        <Key android:keyLabel="m" />
        <Key
            android:codes="@integer/key_dpad_up"
            android:keyLabel="△"
            android:isModifier="true"
            android:isRepeatable="true" />
        <Key
            android:keyLabel="."
            android:popupCharacters="&lt;;:&gt;/?\\"
            android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 6: Bottom - Fn + Ctrl + Alt + ?123 + Space + Arrows -->
    <Row android:rowEdgeFlags="bottom">
        <Key
            android:codes="@integer/key_fn"
            android:keyLabel="Fn"
            android:keyWidth="8.29090909%p"
            android:isModifier="true"
            android:keyEdgeFlags="left" />
        <Key
            android:codes="@integer/key_ctrl_left"
            android:keyLabel="Ctrl"
            android:keyWidth="8.29090909%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_alt_left"
            android:keyLabel="Alt"
            android:keyWidth="8.29090909%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_symbol"
            android:keyLabel="\?123"
            android:keyWidth="8.29090909%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_space"
            android:keyLabel=" "
            android:keyWidth="36.87272727%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_dpad_left"
            android:keyLabel="◁"
            android:keyWidth="7.49090909%p"
            android:isModifier="true"
            android:isRepeatable="true" />
        <Key
            android:codes="@integer/key_dpad_down"
            android:keyLabel="▽"
            android:keyWidth="7.49090909%p"
            android:isModifier="true"
            android:isRepeatable="true" />
        <Key
            android:codes="@integer/key_dpad_up"
            android:keyLabel="△"
            android:keyWidth="7.49090909%p"
            android:isModifier="true"
            android:isRepeatable="true" />
        <Key
            android:codes="@integer/key_dpad_right"
            android:keyLabel="▷"
            android:keyWidth="7.49090909%p"
            android:isModifier="true"
            android:isRepeatable="true"
            android:keyEdgeFlags="right" />
    </Row>
</Keyboard>
