<?xml version="1.0" encoding="utf-8"?>
<!-- 
PC Compact Layout - 6 rows con utilidad avanzada
Todas las letras @ 10%p, auto-centering para rows incompletas
-->
<Keyboard
    xmlns:android="http://schemas.android.com/apk/res-auto"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="@dimen/key_bottom_gap">

    <!-- Row 1: Always visible utility row -->
    <Row android:rowEdgeFlags="top">
        <Key android:codes="@integer/key_escape" android:keyLabel="Esc" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:keyLabel="\`" android:shiftLabel="~" />
        <Key android:keyLabel="-" android:shiftLabel="_" />
        <Key android:keyLabel="\\" android:shiftLabel="|" />
        <Key android:keyLabel=";" android:shiftLabel=":" />
        <Key android:keyLabel="=" android:shiftLabel="+" />
        <Key android:keyLabel="[" android:shiftLabel="{" />
        <Key android:keyLabel="]" android:shiftLabel="}" />
        <Key android:codes="@integer/key_home" android:keyLabel="Home" android:isModifier="true" />
        <Key android:codes="@integer/key_end" android:keyLabel="End" android:isModifier="true" />
        <Key android:codes="@integer/key_forward_del" android:keyLabel="Del" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: Numbers 0-9 + Delete -->
    <Row>
        <Key android:keyLabel="1" android:popupCharacters="!\`" android:keyWidth="7.09%p" android:keyEdgeFlags="left" />
        <Key android:keyLabel="2" android:popupCharacters="@~" android:keyWidth="7.09%p" />
        <Key android:keyLabel="3" android:popupCharacters="#-" android:keyWidth="7.09%p" />
        <Key android:keyLabel="4" android:popupCharacters="$_" android:keyWidth="7.09%p" />
        <Key android:keyLabel="5" android:popupCharacters="%=" android:keyWidth="7.09%p" />
        <Key android:keyLabel="6" android:popupCharacters="^+" android:keyWidth="7.09%p" />
        <Key android:keyLabel="7" android:popupCharacters="{&amp;" android:keyWidth="7.09%p" />
        <Key android:keyLabel="8" android:popupCharacters="}*" android:keyWidth="7.09%p" />
        <Key android:keyLabel="9" android:popupCharacters="([" android:keyWidth="7.09%p" />
        <Key android:keyLabel="0" android:popupCharacters=")]" android:keyWidth="7.09%p" />
        <Key android:codes="@integer/key_delete" android:keyLabel="⌫" android:keyWidth="12.09%p" android:isModifier="true" android:isRepeatable="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: QWERTY (10 letras @ 10% = 100%, ocupa todo el ancho) -->
    <Row>
        <Key android:keyLabel="q" android:keyEdgeFlags="left" />
        <Key android:keyLabel="w" />
        <Key android:keyLabel="e" />
        <Key android:keyLabel="r" />
        <Key android:keyLabel="t" />
        <Key android:keyLabel="y" />
        <Key android:keyLabel="u" />
        <Key android:keyLabel="i" />
        <Key android:keyLabel="o" />
        <Key android:keyLabel="p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 4: ASDFGHJKL (9 letras @ 10% = 90%, auto-centrado con 5% padding) -->
    <Row>
        <Key android:keyLabel="a" android:keyEdgeFlags="left" />
        <Key android:keyLabel="s" />
        <Key android:keyLabel="d" />
        <Key android:keyLabel="f" />
        <Key android:keyLabel="g" />
        <Key android:keyLabel="h" />
        <Key android:keyLabel="j" />
        <Key android:keyLabel="k" />
        <Key android:keyLabel="l" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 5: Shift + ZXCVBNM + ↑ + Enter -->
    <Row>
        <Key android:codes="@integer/key_shift" android:keyLabel="⇧" android:isModifier="true" android:isSticky="true" android:keyEdgeFlags="left" />
        <Key android:keyLabel="z" />
        <Key android:keyLabel="x" />
        <Key android:keyLabel="c" />
        <Key android:keyLabel="v" />
        <Key android:keyLabel="b" />
        <Key android:keyLabel="n" />
        <Key android:keyLabel="m" />
        <Key android:codes="@integer/key_dpad_up" android:keyLabel="△" android:isModifier="true" android:isRepeatable="true" />
        <Key android:codes="@integer/key_return" android:keyLabel="↵" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 6: Bottom -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_tab" android:keyLabel="Tab" android:keyWidth="10%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_ctrl_left" android:keyLabel="Ctrl" android:keyWidth="10%p" android:isModifier="true" />
        <Key android:codes="@integer/key_symbol" android:keyLabel="\?123" android:keyWidth="10%p" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyLabel=" " android:keyWidth="24%p" android:isModifier="true" />
        <Key android:keyLabel="." android:popupCharacters=",&lt;;:&gt;/?\\\&apos;\&quot;|" android:keyWidth="10%p" />
        <Key android:codes="@integer/key_dpad_left" android:keyLabel="◁" android:keyWidth="9%p" android:isModifier="true" android:isRepeatable="true" />
        <Key android:codes="@integer/key_dpad_down" android:keyLabel="▽" android:keyWidth="9%p" android:isModifier="true" android:isRepeatable="true" />
        <Key android:codes="@integer/key_dpad_right" android:keyLabel="▷" android:keyWidth="9%p" android:isModifier="true" android:isRepeatable="true" android:keyEdgeFlags="right" />
    </Row>
</Keyboard>
