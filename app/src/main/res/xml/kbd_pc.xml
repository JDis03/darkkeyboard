<?xml version="1.0" encoding="utf-8"?>
<!-- 
QWERTY Standard Layout
5 rows con proporciones estándar de teclado PC
-->
<Keyboard
    xmlns:android="http://schemas.android.com/apk/res-auto"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="@dimen/key_bottom_gap">

    <!-- Row 1: Números 1-0 (extension row) -->
    <Row android:extension="true" android:rowEdgeFlags="top">
        <Key android:keyLabel="1" android:shiftLabel="!" android:keyEdgeFlags="left" />
        <Key android:keyLabel="2" android:shiftLabel="@" />
        <Key android:keyLabel="3" android:shiftLabel="#" />
        <Key android:keyLabel="4" android:shiftLabel="$" />
        <Key android:keyLabel="5" android:shiftLabel="%" />
        <Key android:keyLabel="6" android:shiftLabel="^" />
        <Key android:keyLabel="7" android:shiftLabel="&amp;" />
        <Key android:keyLabel="8" android:shiftLabel="*" />
        <Key android:keyLabel="9" android:shiftLabel="(" />
        <Key android:keyLabel="0" android:shiftLabel=")" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: QWERTY (standard 10 keys) -->
    <Row>
        <Key android:keyLabel="q" android:keyEdgeFlags="left" />
        <Key android:keyLabel="w" />
        <Key android:keyLabel="e" />
        <Key android:keyLabel="r" />
        <Key android:keyLabel="t" />
        <Key android:keyLabel="y" />
        <Key android:keyLabel="u" />
        <Key android:keyLabel="i" />
        <Key android:keyLabel="o" />
        <Key android:keyLabel="p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: ASDFGHJKL (9 keys with Tab) -->
    <Row>
        <Key
            android:codes="@integer/key_tab"
            android:keyLabel="Tab"
            android:keyWidth="13%p"
            android:isModifier="true"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="a" android:keyWidth="9.66%p" />
        <Key android:keyLabel="s" android:keyWidth="9.66%p" />
        <Key android:keyLabel="d" android:keyWidth="9.66%p" />
        <Key android:keyLabel="f" android:keyWidth="9.66%p" />
        <Key android:keyLabel="g" android:keyWidth="9.66%p" />
        <Key android:keyLabel="h" android:keyWidth="9.66%p" />
        <Key android:keyLabel="j" android:keyWidth="9.66%p" />
        <Key android:keyLabel="k" android:keyWidth="9.66%p" />
        <Key android:keyLabel="l" android:keyWidth="9.66%p" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 4: Shift + ZXCVBNM + Delete (estándar) -->
    <Row>
        <Key
            android:codes="@integer/key_shift"
            android:keyLabel="⇧"
            android:keyWidth="15%p"
            android:isModifier="true"
            android:isSticky="true"
            android:keyEdgeFlags="left" />
        <Key android:keyLabel="z" android:keyWidth="10.625%p" />
        <Key android:keyLabel="x" android:keyWidth="10.625%p" />
        <Key android:keyLabel="c" android:keyWidth="10.625%p" />
        <Key android:keyLabel="v" android:keyWidth="10.625%p" />
        <Key android:keyLabel="b" android:keyWidth="10.625%p" />
        <Key android:keyLabel="n" android:keyWidth="10.625%p" />
        <Key android:keyLabel="m" android:keyWidth="10.625%p" />
        <Key
            android:codes="@integer/key_delete"
            android:keyLabel="⌫"
            android:keyWidth="15.625%p"
            android:isModifier="true"
            android:isRepeatable="true"
            android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 5: Bottom row (Ctrl, Alt, ?123, Space, ., ,, Enter) -->
    <Row android:rowEdgeFlags="bottom">
        <Key
            android:codes="@integer/key_ctrl_left"
            android:keyLabel="Ctrl"
            android:keyWidth="12%p"
            android:isModifier="true"
            android:keyEdgeFlags="left" />
        <Key
            android:codes="@integer/key_alt_left"
            android:keyLabel="Alt"
            android:keyWidth="10%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_symbol"
            android:keyLabel="\?123"
            android:keyWidth="13%p"
            android:isModifier="true" />
        <Key
            android:codes="@integer/key_space"
            android:keyLabel=" "
            android:keyWidth="30%p"
            android:isModifier="true" />
        <Key android:keyLabel="," android:keyWidth="10%p" />
        <Key android:keyLabel="." android:keyWidth="10%p" />
        <Key
            android:codes="@integer/key_return"
            android:keyLabel="↵"
            android:keyWidth="15%p"
            android:isModifier="true"
            android:keyEdgeFlags="right" />
    </Row>
</Keyboard>
