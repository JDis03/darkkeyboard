<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/keyboard_input_view"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp"
        android:clipToPadding="false">

        <!-- Clipboard & Selection Toolbar - aparece cuando hay clipboard o seleccion -->
        <FrameLayout
                android:id="@+id/clipboard_chip_container"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#2D2D2D"
                android:visibility="gone"
                android:paddingHorizontal="8dp">

                <!-- Paste Chip (cuando hay clipboard) -->
                <LinearLayout
                        android:id="@+id/clipboard_chip_content"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="visible">

                        <TextView
                                android:id="@+id/clipboard_chip_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="14sp" />

                        <TextView
                                android:id="@+id/clipboard_chip_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="#BD93F9"
                                android:textSize="13sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginHorizontal="8dp" />

                        <TextView
                                android:id="@+id/clipboard_chip_paste"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="PEGAR"
                                android:textColor="#50FA7B"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="8dp"
                                android:background="?android:attr/selectableItemBackground" />

                        <TextView
                                android:id="@+id/clipboard_chip_history"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📋"
                                android:textColor="#BD93F9"
                                android:textSize="16sp"
                                android:paddingHorizontal="8dp"
                                android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <!-- Selection Toolbar (cuando hay texto seleccionado) -->
                <LinearLayout
                        android:id="@+id/selection_toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                                android:id="@+id/selection_toolbar_select_all"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="SELECCIONAR"
                                android:textColor="#BD93F9"
                                android:textSize="11sp"
                                android:background="?android:attr/selectableItemBackground" />

                        <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#44475A" />

                        <TextView
                                android:id="@+id/selection_toolbar_cut"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="CORTAR"
                                android:textColor="#F8F8F2"
                                android:textSize="11sp"
                                android:background="?android:attr/selectableItemBackground" />

                        <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#44475A" />

                        <TextView
                                android:id="@+id/selection_toolbar_copy"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="COPIAR"
                                android:textColor="#F8F8F2"
                                android:textSize="11sp"
                                android:background="?android:attr/selectableItemBackground" />

                        <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#44475A" />

                        <TextView
                                android:id="@+id/selection_toolbar_paste"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="PEGAR"
                                android:textColor="#50FA7B"
                                android:textSize="11sp"
                                android:background="?android:attr/selectableItemBackground" />

                </LinearLayout>

        </FrameLayout>

        <!-- LatinKeyboardView -->
        <FrameLayout
                android:id="@+id/keyboard_frame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

</LinearLayout>
